<idea-plugin>
    <id>org.mc-stan.stan</id>
    <name>Stan Language Support</name>
    <vendor>Community</vendor>
    <description><![CDATA[
        Syntax highlighting support for the Stan statistical modeling language.<br/>
        Stan is a probabilistic programming language for Bayesian statistical inference,
        full Bayesian statistical inference with MCMC sampling, approximate Bayesian
        inference with variational inference, and penalized maximum likelihood estimation.<br/><br/>
        Features:
        <ul>
            <li>Syntax highlighting for keywords, types, built-in functions, and distributions</li>
            <li>Comment highlighting (// and /* */ and # styles)</li>
            <li>Number and string literal highlighting</li>
            <li>Customizable colors via Settings → Editor → Color Scheme → Stan</li>
        </ul>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action id="Stan.NewFile"
                class="org.intellij.stan.StanCreateFileAction"
                text="Stan File"
                description="Create a new Stan model file">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewFile"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Stan"
            implementationClass="org.intellij.stan.StanFileType"
            fieldName="INSTANCE"
            language="Stan"
            extensions="stan"/>

        <lang.parserDefinition
            language="Stan"
            implementationClass="org.intellij.stan.StanParserDefinition"/>

        <lang.syntaxHighlighterFactory
            language="Stan"
            implementationClass="org.intellij.stan.StanSyntaxHighlighterFactory"/>

        <colorSettingsPage
            implementation="org.intellij.stan.StanColorSettingsPage"/>

        <completion.contributor
            language="Stan"
            implementationClass="org.intellij.stan.StanCompletionContributor"/>

        <localInspection
            language="Stan"
            displayName="Reserved word used as identifier"
            groupName="Stan"
            implementationClass="org.intellij.stan.StanReservedWordAnnotator"
            enabledByDefault="true"
            level="ERROR"/>

        <localInspection
            language="Stan"
            displayName="Consecutive unary operators"
            groupName="Stan"
            implementationClass="org.intellij.stan.StanConsecutiveUnaryInspection"
            enabledByDefault="true"
            level="WARNING"/>

        <localInspection
            language="Stan"
            displayName="Undeclared variable"
            groupName="Stan"
            implementationClass="org.intellij.stan.StanUndeclaredVariableInspection"
            enabledByDefault="true"
            level="ERROR"/>

        <localInspection
            language="Stan"
            displayName="Function call type/arity mismatch"
            groupName="Stan"
            implementationClass="org.intellij.stan.StanFunctionCallInspection"
            enabledByDefault="true"
            level="ERROR"/>

        <localInspection
            language="Stan"
            displayName="Type mismatch"
            groupName="Stan"
            implementationClass="org.intellij.stan.StanTypeMismatchInspection"
            enabledByDefault="true"
            level="ERROR"/>

        <localInspection
            language="Stan"
            displayName="Unused variable"
            groupName="Stan"
            implementationClass="org.intellij.stan.StanUnusedVariableInspection"
            enabledByDefault="true"
            level="WARNING"/>

        <localInspection
            language="Stan"
            displayName="_rng function called outside allowed context"
            groupName="Stan"
            implementationClass="org.intellij.stan.StanRngCallContextInspection"
            enabledByDefault="true"
            level="ERROR"/>
    </extensions>
</idea-plugin>
